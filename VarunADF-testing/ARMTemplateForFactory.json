		{
			"name": "[concat(parameters('factoryName'), '/CDC_LocalServer_ADLS')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "LocalServer_ADLS_CDC",
						"type": "Copy",
						"dependsOn": [],
						"policy": {
							"timeout": "0.00:30:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"source": {
								"type": "SqlServerSource",
								"sqlReaderQuery": "SELECT * FROM med_data\nWHERE updated_time > DATEADD(MINUTE, -2, CURRENT_TIMESTAMP)\n",
								"queryTimeout": "00:10:00",
								"isolationLevel": "ReadCommitted",
								"partitionOption": "None"
							},
							"sink": {
								"type": "ParquetSink",
								"storeSettings": {
									"type": "AzureBlobFSWriteSettings",
									"maxConcurrentConnections": 2,
									"copyBehavior": "FlattenHierarchy"
								},
								"formatSettings": {
									"type": "ParquetWriteSettings"
								}
							},
							"enableStaging": false,
							"parallelCopies": 2,
							"enableSkipIncompatibleRow": true,
							"translator": {
								"type": "TabularTranslator",
								"mappings": [
									{
										"source": {
											"name": "claim_id",
											"type": "Int32",
											"physicalType": "int"
										},
										"sink": {
											"name": "claim_id",
											"type": "Int32",
											"physicalType": "INT_32"
										}
									},
									{
										"source": {
											"name": "encounter_id",
											"type": "Int32",
											"physicalType": "int"
										},
										"sink": {
											"name": "encounter_id",
											"type": "Int32",
											"physicalType": "INT_32"
										}
									},
									{
										"source": {
											"name": "claim_amount",
											"type": "Double",
											"physicalType": "float"
										},
										"sink": {
											"name": "claim_amount",
											"type": "Double",
											"physicalType": "DOUBLE"
										}
									},
									{
										"source": {
											"name": "updated_time",
											"type": "DateTime",
											"physicalType": "datetime"
										},
										"sink": {
											"name": "updated_time",
											"type": "DateTime",
											"physicalType": "INT_96"
										}
									}
								],
								"typeConversion": true,
								"typeConversionSettings": {
									"allowDataTruncation": true,
									"treatBooleanAsNumber": false
								}
							}
						},
						"inputs": [
							{
								"referenceName": "CDC_test",
								"type": "DatasetReference",
								"parameters": {}
							}
						],
						"outputs": [
							{
								"referenceName": "CDC_ADLS",
								"type": "DatasetReference",
								"parameters": {}
							}
						]
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"parameters": {
					"Dummy": {
						"type": "string",
						"defaultValue": "Dummy"
					},
					"Dummy_varun1": {
						"type": "string",
						"defaultValue": "Dummy_varun2"
					}
				},
				"annotations": [],
				"lastPublishTime": "2026-04-21T11:16:46Z"
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/CDC_test')]",
				"[concat(variables('factoryId'), '/datasets/CDC_ADLS')]"
			]
		},
