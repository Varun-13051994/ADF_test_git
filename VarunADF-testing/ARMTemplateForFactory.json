																},
																"sink": {
																	"name": "product",
																	"type": "UTF8"
																}
															},
															{
																"source": {
																	"name": "amount",
																	"type": "INT64"
																},
																"sink": {
																	"name": "amount",
																	"type": "INT64"
																}
															}
														],
														"typeConversion": true,
														"typeConversionSettings": {
															"allowDataTruncation": false,
															"treatBooleanAsNumber": false
														}
													}
												},
												"inputs": [
													{
														"referenceName": "LocalParquetFiles",
														"type": "DatasetReference",
														"parameters": {}
													}
												],
												"outputs": [
													{
														"referenceName": "LocalToADLS",
														"type": "DatasetReference",
														"parameters": {}
													}
												]
											}
										]
									}
								}
							]
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
